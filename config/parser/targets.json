{
  "type_files": [
    "data/common",
    "data/api/QA_tc.h"
  ],
  "interface_files": [
    "data/api/**/*.h",
    "data/QA.c"
  ],
  "target_interfaces": [
    "QA4A_request_align_periodic",
    "QA4A_request_align_periodic2"
  ],
  "output": {
    "dir": "output",
    "filename_format": "parse_result_{interface}_{datetime}.json",
    "mode": "full",
    "scope": "all"
  },
  "variation": {
    "mode": "mark",
    "variables": [
      "QA4A_request_align_periodic.chunk_id",
      "QA4A_request_align_periodic.align_scan_base.a",
      "QA4A_request_align_periodic.align_scan_periodic.other_struct[*].some_string"
    ]
  },
  "includes": "profiles.json"
}
